alias lg=lazygit
alias zl=zellij
alias la='ls -a'
alias nvide=neovide
alias sudoe='sudo $(which nvim) -u /home/jadepoet/.config/nvim/init.lua'

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
